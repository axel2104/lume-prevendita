# Credenziali PerfectGym (le STESSE della dashboard — header X-Client-Id / X-Client-Secret)
PG_CLIENT_ID=
PG_CLIENT_SECRET=

# Base URL dell'API PerfectGym (default produzione Lume)
PG_API_BASE=https://lumefitness.perfectgym.com/Api

# Dominio autorizzato a chiamare il backend (la pagina che ospita il form)
# In produzione metti es. https://www.lumefitness.it (evita *)
ALLOWED_ORIGIN=https://www.lumefitness.it

# Pagina di ritorno dopo la registrazione della carta su PerfectGym
THANK_YOU_URL=https://www.lumefitness.it/prevendita/grazie

# (Opzionale) data di inizio contratto fissa, formato yyyy-mm-dd. Vuoto = oggi.
CONTRACT_START_DATE=

# (Opzionale) chiave per proteggere /api/payment-plans
ADMIN_KEY=
